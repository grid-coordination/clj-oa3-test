;; Test suite ordering — dependencies are declared via :suite-deps/requires.
;; The suite-deps plugin auto-includes prerequisite suites when using --focus.
;;
;; Example: `clojure -M:test --focus :mqtt` will also run :programs and :vens.

#kaocha/v1
 {:plugins [:kaocha.plugin/suite-deps :kaocha.plugin/test-report]
  :tests [{:id          :notifiers
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["notifiers-test$"]}
          {:id          :programs
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["programs-test$"]}
          {:id          :vens
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["vens-test$"]}
          {:id          :events
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["events-test$"]
           :suite-deps/requires [:programs]}
          {:id          :resources
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["resources-test$"]
           :suite-deps/requires [:vens]}
          {:id          :reports
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["reports-test$"]
           :suite-deps/requires [:programs]}
          {:id          :subscriptions
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["subscriptions-test$"]
           :suite-deps/requires [:programs]}
          {:id          :topics
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["topics-test$"]
           :suite-deps/requires [:vens]}
          {:id          :channel
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["channel-test$"]
           :suite-deps/requires [:programs :vens]}
          {:id          :ven-client
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["ven-client-test$"]
           :suite-deps/requires [:programs :vens]}
          {:id          :mqtt
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["mqtt-test$"]
           :suite-deps/requires [:programs :vens]}
          {:id          :mqtt-auth
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["mqtt-auth-test$"]
           :suite-deps/requires [:programs :vens]}
          {:id          :webhook
           :type        :kaocha.type/clojure.test
           :source-paths []
           :test-paths  ["test"]
           :ns-patterns ["webhook-test$"]
           :suite-deps/requires [:programs]}]
  :color?     true
  :fail-fast? false
  :randomize? false}
