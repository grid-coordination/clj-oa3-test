;; Copy this file to test-config.edn and adjust for your VTN.
;; test-config.edn is gitignored.

{:vtn-url "http://localhost:8080/openadr3/3.1.0"

 ;; Dual-URL config for two-port VTN architectures.
 ;; If your VTN serves BL (write) and VEN (read) clients on separate ports,
 ;; set :bl-url and :ven-url. If omitted, both fall back to :vtn-url.
 ;; :bl-url  "http://localhost:8081/openadr3/3.1.0"
 ;; :ven-url "http://localhost:8080/openadr3/3.1.0"

 ;; Auth tokens — must match your VTN's token configuration.
 :tokens {:ven1 "ven_token"
          :ven2 "ven_token2"
          :bl   "bl_token"
          :bad  "bad_token"}

 ;; Delay in ms between test suites.
 ;; Set to 0 for fast VTNs, 1000-5000 if you see connection errors.
 :inter-suite-delay-ms 1000

 ;; MQTT settle time in ms — how long to wait after clearing the message
 ;; buffer for retained messages to drain. Increase for slow brokers.
 ;; :mqtt-settle-ms 1000

 ;; MQTT await timeout in ms — max time to wait for expected notifications.
 ;; :mqtt-await-ms 10000

 ;; Expected notifier types the VTN should advertise.
 ;; Defaults to #{:WEBHOOK :MQTT}. For a VTN that only supports MQTT:
 ;; :expected-notifiers #{:MQTT}

 ;; MQTT broker fallback — only used if the VTN's GET /notifiers endpoint
 ;; does not advertise MQTT broker URIs. Normally the broker URLs are
 ;; discovered automatically from the VTN.
 ;; :mqtt-brokers ["tcp://127.0.0.1:1883"]

 ;; VEN port route enablement — override when VTN enables additional
 ;; routes on the VEN port. Defaults match clj-oa3-vtn 0.4.0 defaults:
 ;; programs and events are :read-only, everything else is disabled (false).
 ;; Values: :full, :read-only, or false (disabled).
 ;; :ven-routes {:subscriptions false   ;; VEN subscription CRUD
 ;;              :vens          false
 ;;              :resources     false
 ;;              :reports       false}
 }
